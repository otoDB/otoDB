# Django docs can be found by removing the `OTODB` prefix and substituting `VAR`
# https://docs.djangoproject.com/en/4.2/ref/settings/#std-setting-VAR

# Required for production
OTODB_SECRET_KEY=your-secret-key
OTODB_ALLOWED_HOSTS=.example.com

# Other env vars
OTODB_DEBUG=False
OTODB_DEBUG_TOOLBAR=False
OTODB_TIME_ZONE=UTC
OTODB_INTERNAL_IPS=127.0.0.1

# ---

# Database settings; pick one of these blocks to use
OTODB_DB_SERVICE=
OTODB_DB_PASSFILE=

OTODB_DB_NAME=
OTODB_DB_USER=
OTODB_DB_PASSWORD=
OTODB_DB_HOST=
OTODB_DB_PORT=

# Global configuration settings
OTODB_CONF_SITE_NAME="otoDB"
