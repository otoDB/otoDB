{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Django: Run server",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}\\manage.py",
			"args": [
				"runserver"
			],
			"django": true,
			"justMyCode": true
		},
		{
			"name": "Django: Run tests",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}\\manage.py",
			"args": [
				"test"
			],
			"django": true,
			"justMyCode": true
		},
		{
			"name": "Django: Create superuser",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}\\manage.py",
			"args": [
				"createsuperuser",
				"--noinput"
			],
			"env": {
				"DJANGO_SUPERUSER_USERNAME": "admin",
				"DJANGO_SUPERUSER_PASSWORD": "admin",
				"DJANGO_SUPERUSER_EMAIL": "admin@otodb.net",
			},
			"django": true,
			"justMyCode": false
		},
	]
}
