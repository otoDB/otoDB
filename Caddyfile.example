otodb.net {
	handle_path /static/* {
		root * /srv/static
		file_server
	}

	handle /admin* {
		reverse_proxy backend:8000
	}

	handle /api* {
		reverse_proxy backend:8000
	}

	handle /chores* {
		reverse_proxy backend:8000
	}

	handle /internal/* {
		respond 403
	}

	handle /* {
		reverse_proxy frontend:5173
	}
}
