{
    "manifest_version": 3,
    "name": "otoDB",
    "version": "1.0.0",
    "description": "otoDB is a community-driven website consisting of a collaborative user-managed database and wiki.",

    "content_scripts": [
      {
        "matches": [
          "*://*.youtube.com/watch*",
          "*://*.bilibili.com/video*",
          "*://*.nicovideo.jp/*",
          "*://*.soundcloud.com/*"
        ],
        "js": ["database.js"],
        "css": ["style.css"]
      },
      {
        "matches": [
          "*://*.nicovideo.jp/*"
        ],
        "js": ["niconico.js"]
      },
      {
        "matches": [
          "*://*.nicovideo.jp/*"
        ],
        "js": ["injector.js"],
        "run_at": "document_start"
      }
    ],

    "web_accessible_resources": [
      {
        "resources": ["injected.js"],
        "matches": ["*://*.nicovideo.jp/*"]
      }
    ],
  
    "permissions": [
      "declarativeNetRequestWithHostAccess"
    ],
    "host_permissions": [
      "*://127.0.0.1/*",
      "*://*.nicovideo.jp/*"
    ],
    "declarative_net_request": {
      "rule_resources": [
        {
          "id": "ruleset",
          "enabled": true,
          "path": "rules.json"
        }
      ]
    }
}
