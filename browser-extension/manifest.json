{
    "manifest_version": 3,
    "name": "otoDB",
    "version": "1.0",
    "description": "otoDB is a community-driven website consisting of a collaborative user-managed database and wiki.",

    "content_scripts": [
      {
        "matches": ["*://*.youtube.com/watch*", "*://*.bilibili.com/video*", "*://*.nicovideo.jp/watch*", "*://*.soundcloud.com/*"],
        "js": ["main.js"],
        "css": ["style.css"]
      }
    ],
  
    "host_permissions": ["*://127.0.0.1/*"]
}
